# Telegram Bot Token из @BotFather
BOT_TOKEN=your_telegram_bot_token_here

# Google Sheets ID из URL таблицы
# https://docs.google.com/spreadsheets/d/[SPREADSHEET_ID]/edit
SPREADSHEET_ID=your_google_sheets_id_here

# Опционально: путь к credentials.json (по умолчанию: ./credentials.json)
# GOOGLE_CREDENTIALS_FILE=./credentials.json

# Опционально: для Railway - Base64 закодированный credentials.json
# CREDENTIALS_BASE64=base64_encoded_credentials_here
